# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# PostgreSQL (macOS Homebrew - no password required)
DATABASE_URL=postgresql://postgres:postgres@localhost/groceries

# MongoDB
MONGODB_URI=mongodb://localhost:27017/groceries

# Redis (optional for cart/session caching)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev_jwt_secret_do_not_use_in_production_12345
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_do_not_use_in_production_12345
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
COOKIE_SECRET=dev_cookie_secret_do_not_use_in_production_12345
